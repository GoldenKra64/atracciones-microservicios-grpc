{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "atraccion-ms-route": {
        "ClusterId": "atraccion-ms",
        "CorsPolicy": "AllowFrontend",
        "Match": {
          "Path": "/api/v1/{controller:regex(atracciones|categoria|destino|horario|imagen|incluye|noincluye|resena|tag|ticket|idioma)}/{**catch-all}"
        }
      },
      "tickets-plural-route": {
        "ClusterId": "atraccion-ms",
        "CorsPolicy": "AllowFrontend",
        "Match": {
          "Path": "/api/v1/tickets/{**catch-all}"
        }
      },
      "factura-route": {
        "ClusterId": "factura-ms",
        "CorsPolicy": "AllowFrontend",
        "Match": {
          "Path": "/api/v1/facturas/{**catch-all}"
        }
      },
      "reserva-route": {
        "ClusterId": "reserva-ms",
        "CorsPolicy": "AllowFrontend",
        "Match": {
          "Path": "/api/v1/reservas/{**catch-all}"
        }
      },
      "auth-route": {
        "ClusterId": "auth-ms",
        "CorsPolicy": "AllowFrontend",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        }
      },
      "cliente-route": {
        "ClusterId": "cliente-ms",
        "CorsPolicy": "AllowFrontend",
        "Match": {
          "Path": "/api/v1/cliente/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "atraccion-ms": {
        "HttpClient": {
          "MaxConnectionsPerServer": 1024
        },
        "HttpHandler": {
          "AllowAutoRedirect": false
        },
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7233"
          }
        }
      },
      "auth-ms": {
        "HttpClient": {
          "MaxConnectionsPerServer": 1024
        },
        "HttpHandler": {
          "AllowAutoRedirect": false
        },
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7182"
          }
        }
      },
      "cliente-ms": {
        "HttpClient": {
          "MaxConnectionsPerServer": 1024
        },
        "HttpHandler": {
          "AllowAutoRedirect": false
        },
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7229"
          }
        }
      },
      "factura-ms": {
        "HttpClient": {
          "MaxConnectionsPerServer": 1024
        },
        "HttpHandler": {
          "AllowAutoRedirect": false
        },
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7269"
          }
        }
      },
      "reserva-ms": {
        "HttpClient": {
          "MaxConnectionsPerServer": 1024
        },
        "HttpHandler": {
          "AllowAutoRedirect": false
        },
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7149"
          }
        }
      }
    }
  }
}