{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "atraccion-route": {
        "ClusterId": "atraccion-cluster",
        "Match": {
          "Path": "/api/atraccion/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/{**catch-all}" }
        ]
      },
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/{**catch-all}" }
        ]
      },
      "cliente-route": {
        "ClusterId": "cliente-cluster",
        "Match": {
          "Path": "/api/cliente/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/{**catch-all}" }
        ]
      },
      "factura-route": {
        "ClusterId": "factura-cluster",
        "Match": {
          "Path": "/api/factura/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/{**catch-all}" }
        ]
      },
      "reserva-route": {
        "ClusterId": "reserva-cluster",
        "Match": {
          "Path": "/api/reserva/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "atraccion-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7233"
          }
        }
      },
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7182"
          }
        }
      },
      "cliente-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7229"
          }
        }
      },
      "factura-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7269"
          }
        }
      },
      "reserva-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7149"
          }
        }
      }
    }
  }
}
